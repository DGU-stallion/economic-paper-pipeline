{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "选题研究 Skill 输出 Schema",
  "description": "skill-topic 完成后传递给后续 Skill 的标准数据格式",
  "type": "object",
  "required": ["status", "stage", "research_proposal", "artifacts", "next_skill"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "partial", "user_intervention", "error"],
      "description": "执行状态"
    },
    "stage": {
      "type": "string",
      "const": "topic",
      "description": "阶段标识"
    },
    "research_proposal": {
      "type": "object",
      "required": ["title", "research_question", "hypotheses", "variables", "identification_strategy", "keywords"],
      "properties": {
        "title": {
          "type": "string",
          "description": "研究题目"
        },
        "research_question": {
          "type": "string",
          "description": "SMART 精确研究问题"
        },
        "hypotheses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "statement": { "type": "string" },
              "expected_sign": { "type": "string", "enum": ["+", "-", "?"] }
            }
          },
          "minItems": 1
        },
        "variables": {
          "type": "object",
          "properties": {
            "y_var": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "definition": { "type": "string" },
                "expected_sign": { "type": "string" }
              }
            },
            "d_var": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "definition": { "type": "string" },
                "expected_sign": { "type": "string" }
              }
            },
            "control_vars": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "definition": { "type": "string" }
                }
              }
            }
          }
        },
        "identification_strategy": {
          "type": "string",
          "enum": ["OLS", "FE", "DID", "IV", "RDD", "Other"],
          "description": "识别策略"
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3,
          "maxItems": 8,
          "description": "中英文关键词"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "生成的文件路径列表"
    },
    "next_skill": {
      "type": "string",
      "const": "skill-literature",
      "description": "下一个要激活的 Skill"
    },
    "error_message": {
      "type": "string",
      "description": "错误信息（status=error 时必填）"
    }
  }
}
