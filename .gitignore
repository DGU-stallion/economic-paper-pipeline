# ========================
# Data (all projects)
# ========================
papers/*/data/raw/*
!papers/*/data/raw/.gitkeep
papers/*/data/clean/*
!papers/*/data/clean/.gitkeep

# ========================
# User paper projects (keep only demo-paper in repo)
# ========================
papers/*
!papers/demo-paper/
!papers/demo-paper/*

# ========================
# Stata outputs and logs
# ========================
papers/*/analysis/logs/*.log
papers/*/analysis/logs/*.smcl
papers/*/analysis/logs/*.dta

# ========================
# Pipeline state (machine-local)
# ========================
papers/*/pipeline_state.json
papers/*/conversation.json
papers/*/context/

# ========================
# Root-level temporary logs (cleaned up, but just in case)
# ========================
stata_batch__*.log
doctor_test.log

# ========================
# MCP working directories (machine-local)
# ========================
.statamcp/
.playwright-mcp/

# ========================
# Python
# ========================
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ========================
# IDE
# ========================
.vscode/
.idea/

# ========================
# OS
# ========================
.DS_Store
Thumbs.db

# ========================
# Claude Code (user-specific config)
# ========================
.claude/

# ========================
# Pipeline state (machine-local, per project)
# ========================
config/current_project.json
.config/               # global installation mode config
papers/*/pipeline_state.json
current_project.json  # legacy, was in root
papers/*/.cache/      # incremental execution hash cache

# ========================
# Unfinished templates (local development)
# ========================
templates/paper/swufe-thesis.*

# ========================
# Other MCP working directories
# ========================
.understand-anything/

# ========================
# LaTeX build artifacts (all projects)
# ========================
papers/*/paper/*.aux
papers/*/paper/*.bbl
papers/*/paper/*.bcf
papers/*/paper/*.blg
papers/*/paper/*.fdb_latexmk
papers/*/paper/*.fls
papers/*/paper/*.out
papers/*/paper/*.run.xml
papers/*/paper/*.synctex.gz
papers/*/paper/*.toc
papers/*/paper/*.lof
papers/*/paper/*.lot
papers/*/paper/*.nlo
papers/*/paper/*.nls
papers/*/paper/*.brf
papers/*/paper/*.nav
papers/*/paper/*.snm
papers/*/paper/*.vrb

# Compiled PDF (all projects - source of truth is local compile)
papers/*/paper/main.pdf

# Template LaTeX artifacts
templates/paper/*.aux
templates/paper/main.pdf

# ========================
# Archive (optional: archived projects not tracked in git)
# ========================
archive/
