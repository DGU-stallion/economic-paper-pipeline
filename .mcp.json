{
  "mcpServers": {
    "stata-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "stata-mcp"
      ]
    },
    "paper-search-mcp": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--with",
        "paper-search-mcp",
        "python",
        "-m",
        "paper_search_mcp.server"
      ]
    }
  }
}
